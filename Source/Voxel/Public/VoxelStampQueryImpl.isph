enum EVoxelHeightBlendMode
{
	HeightBlendMode_Max,
	HeightBlendMode_Min,
	HeightBlendMode_Override,
};

enum EVoxelVolumeBlendMode
{
	VolumeBlendMode_Additive,
	VolumeBlendMode_Subtractive,
	VolumeBlendMode_Intersect,
	VolumeBlendMode_Override,
};